---
import BaseLayout from '@/layouts/base-layout.astro';
import Header from "@/components/custom/header.astro";
import Footer from "@/components/custom/footer.astro";

interface Props {
  title?: string;
  description?: string;
  socialImage?: string;
}
---

<BaseLayout {...Astro.props}>
  <Header />
  <main class="grow">
    <slot />
  </main>
  <Footer />
</BaseLayout>
